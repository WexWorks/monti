# Build outputs
build/
out/
cmake-build-*/
coverage/
tests/output/*.png
coverage.xml
LastCoverageResults.log

# IDE files
.vs/
*.vcxproj.user
.idea/
.cache/
.vscode/

# Compiled shaders
*.spv

# Scene assets (downloaded at build/configure time)
scenes/khronos/

# Extended scene assets (multi-GB, downloaded via MONTI_DOWNLOAD_EXTENDED_SCENES)
scenes/extended/

# Environment maps (downloaded HDRIs, shared between training and tests)
scenes/environments/

# Training scenes (downloaded by training/scripts/download_scenes.py)
scenes/training/

# Golden reference images (generated locally)
tests/golden/

# App assets (fonts downloaded at build time)
app/assets/

# Capture output (runtime output, not the capture/ source directory)
capture_output/

# OS files
Thumbs.db
.DS_Store

# Dependencies fetched by CMake
_deps/
external/

# Code coverage output
coverage_report/
coverage.xml

# Training data and Python venv (generated, not checked in)
training_data/
training_data_validation/
training_data*_st/
training/.venv/
training/data_cache/
training/__pycache__/
training/**/__pycache__/
training/.pytest_cache/
training/**/*.egg-info/
training_data*_test/
